{
  "name": "capacitor-triptracker",
  "version": "1.0.0",
  "description": "Capacitor plugin for TripTracker — GPS trip tracking, geofencing, voice feedback. iOS + Android.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": ["dist/", "ios/", "android/", "src/"],
  "keywords": ["capacitor", "plugin", "ios", "android", "triptracker", "gps", "geofence"],
  "capacitor": {
    "ios": { "src": "ios" },
    "android": { "src": "android" }
  },
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "peerDependencies": {
    "@capacitor/core": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^6.0.0",
    "typescript": "~5.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0"
  }
}
